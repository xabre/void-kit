<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled: VoidKit requires direct access to system directories.
	     Users must grant Full Disk Access in System Settings → Privacy & Security → Full Disk Access. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
